# TextMeBot API Key
TEXTMEBOT_API_KEY=your_textmebot_api_key

# Webhook server port (TextMeBot sends incoming messages here)
WEBHOOK_PORT=8090

# Claude Code
ANTHROPIC_API_KEY=sk-ant-...
APPROVED_DIRECTORY=/path/to/your/projects
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_MAX_TURNS=25
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Security - comma-separated WhatsApp numbers allowed to use the bot
ALLOWED_NUMBERS=5500000000000,5500000000001

# Bot behavior
BOT_NAME=WhatsMCP
VERBOSE_LEVEL=1
# DEBUG=false
